# Discord values can now be configured from Admin Web Setup Wizard.
# Leave empty on first boot; the wizard writes data/runtime-config.json.
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
LOG_LEVEL=info

# Discord Developer Portal:
# Enable Message Content Intent if you want automod to scan message text.

# Optional comma-separated Discord user IDs allowed to run setup.
# If empty, any server Administrator can run /setup-vireon.
SETUP_ALLOWED_USER_IDS=

# Admin panel is enabled by default for the first-run Setup Wizard. Protect it behind HTTPS/tunnel before public use.
ADMIN_PANEL_ENABLED=true
ADMIN_PANEL_HOST=0.0.0.0
ADMIN_PANEL_PORT=8787
ADMIN_JWT_SECRET=
ADMIN_JWT_TTL=15m
ADMIN_REFRESH_TOKEN_DAYS=14
ADMIN_TOTP_ENCRYPTION_KEY=
ADMIN_LOCKOUT_MAX_ATTEMPTS=5
ADMIN_LOCKOUT_MINUTES=15
ADMIN_DEFAULT_EMAIL=admin@vireon.local
ADMIN_DEFAULT_PASSWORD=

# Optional web push notifications for the installable PWA dashboard.
# Generate keys with: npm run push:vapid
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@vireon.local

# Runtime config written by the first-run wizard.
BOT_DATA_DIR=./data
RUNTIME_CONFIG_PATH=./data/runtime-config.json
SETUP_WIZARD_ENABLED=true
SETUP_WIZARD_RESTART_ON_FINISH=true

# Serious bot database profile. JSON remains dev/fallback only.
STORAGE_DRIVER=prisma
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://vireon:vbos_change_me@postgres:5432/vbos?schema=public
DATABASE_URL_LEDGER=postgresql://vireon:vbos_ledger_change_me@postgres-ledger:5432/vbos_ledger?schema=public
LEDGER_STORAGE_DRIVER=prisma
LEDGER_DATA_DIR=./data/ledger

# Optional wallet registration / payment link module.
# One HD master seed source is required for /register custodial.
# Prefer a vault-mounted file in production; use HEX/BASE64 only for controlled env secret storage.
PUBLIC_BASE_URL=http://127.0.0.1:8787
PAYMENT_LINK_SECRET=replace_with_at_least_32_random_characters
WALLET_HD_MASTER_SEED_FILE=
WALLET_HD_MASTER_SEED_BASE64=
WALLET_HD_MASTER_SEED_HEX=
WALLET_HD_MASTER_SEED=
WALLET_DEFAULT_DAILY_LIMIT=0
WALLET_DEFAULT_BALANCE_LIMIT=0
VIREON_WALLET_ADDRESS_PREFIX=vire
VIREON_WALLET_SIGNATURE_VERIFY_URL=
WALLET_ALLOW_MOCK_SIGNATURES=false
WALLET_MOCK_SIGNATURE_SECRET=replace_with_dev_only_mock_signature_secret

# Optional automated database backups.
# BACKUP_CRON uses UTC 5-field cron syntax. Default below means 03:00 UTC daily.
BACKUP_ENABLED=false
BACKUP_RUN_ON_STARTUP=false
BACKUP_CRON=0 3 * * *
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
BACKUP_INCLUDE_JSON_DATA=true

# Optional S3-compatible upload target: AWS S3, Cloudflare R2, MinIO, Wasabi etc.
BACKUP_S3_ENABLED=false
BACKUP_S3_ENDPOINT=https://s3.amazonaws.com
BACKUP_S3_REGION=auto
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=vbos
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
BACKUP_S3_FORCE_PATH_STYLE=true

# Optional Vireon chain client mode and status endpoint.
# disabled: health reports chain client as disabled but OK.
# mock: /vireon-status returns clearly marked simulated metrics.
# rpc: /health checks VIREON_CHAIN_RPC_URL and /vireon-status reads JSON metrics.
VIREON_CHAIN_MODE=disabled
VIREON_CHAIN_HEALTH_URL=
VIREON_CHAIN_RPC_URL=
VIREON_CHAIN_STATUS_URL=
VIREON_CHAIN_STATUS_PATH=/status
VIREON_CHAIN_REWARDS_URL=
VIREON_CHAIN_REWARDS_PATH=/rewards/{address}
VIREON_CHAIN_PAYMENT_FEE_URL=
VIREON_CHAIN_PAYMENT_FEE_PATH=/payments/estimate-fee
VIREON_CHAIN_PAYMENT_BROADCAST_URL=
VIREON_CHAIN_PAYMENT_BROADCAST_PATH=/payments/broadcast
VIREON_CHAIN_TX_STATUS_URL=
VIREON_CHAIN_TX_STATUS_PATH=/transactions/{txHash}
VIREON_CHAIN_HEALTH_TIMEOUT_MS=3000
VIREON_CHAIN_STATUS_TIMEOUT_MS=3000
VIREON_CHAIN_REWARDS_TIMEOUT_MS=3000
VIREON_CHAIN_PAYMENT_TIMEOUT_MS=3000
VIREON_CHAIN_TX_STATUS_TIMEOUT_MS=3000
VIREON_CHAIN_MOCK_PAYMENT_FEE=0.001
VIREON_CHAIN_CACHE_ENABLED=true
VIREON_CHAIN_HEALTH_CACHE_TTL_MS=10000
VIREON_CHAIN_STATUS_CACHE_TTL_MS=15000
VIREON_CHAIN_REWARDS_CACHE_TTL_MS=30000
VIREON_CHAIN_TX_STATUS_CACHE_TTL_MS=5000
VIREON_CHAIN_STALE_CACHE_TTL_MS=120000
VIREON_CHAIN_RPC_RATE_LIMIT_PER_MINUTE=60
VIREON_CHAIN_RPC_RATE_LIMIT_WINDOW_MS=60000

# Optional on-chain <-> ledger reconciliation worker.
ONCHAIN_SYNC_ENABLED=false
ONCHAIN_SYNC_INTERVAL_MS=30000
ONCHAIN_SYNC_BATCH_SIZE=100
ONCHAIN_SYNC_MIN_CONFIRMATIONS=6
ONCHAIN_SYNC_FINALITY_CONFIRMATIONS=24
ONCHAIN_SYNC_TRACK_STATUSES=broadcasted,broadcast_mock,onchain_seen,onchain_confirming,onchain_confirmed

# Optional Lavalink music module.
# In Docker Compose, use LAVALINK_HOST=lavalink.
MUSIC_ENABLED=false
LAVALINK_HOST=127.0.0.1
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false
# Optional multi-node override:
# LAVALINK_NODES=[{"name":"primary","url":"http://lavalink-a:2333","auth":"password-a"},{"name":"backup","url":"http://lavalink-b:2333","auth":"password-b"}]
MUSIC_DEFAULT_VOLUME=70
