# Vireon Docker Build Context — exclude everything unnecessary
# Context root: Vireon-Network-Main/ (set via compose.yaml build.context: ../..)

# Rust build artefacts
target/

# Version control
.git/
.gitignore
.gitattributes
.gitmodules

# Large directories not needed at runtime
docs/
shared/brand/
shared/test-vectors/

