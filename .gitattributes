* text=auto

# Linux and container entrypoints must remain executable by /usr/bin/env.
*.sh text eol=lf
Dockerfile text eol=lf
*.Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.conf text eol=lf

# Windows-native scripts retain CRLF for compatibility with legacy hosts.
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary assets must never be normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.woff binary
*.woff2 binary
*.zip binary
*.gz binary
*.zst binary
*.exe binary
*.dll binary
