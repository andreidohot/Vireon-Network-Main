COMPOSE_PROJECT_NAME=veiron-control-plane
STACK_VERSION=2.1.0-no-autoupdate
TZ=Europe/Bucharest
VEIRON_HOST_WORKSPACE=/absolute/path/Veiron-Network-Main/veiron-release/vps-control-plane
VEIRON_HOST_REPO=/absolute/path/Veiron-Network-Main
VEIRON_VERSION=2.1.0-no-autoupdate
VEIRON_RUNTIME_IMAGE=ghcr.io/andreidohot/veiron-runtime
VEIRON_OPS_IMAGE=ghcr.io/andreidohot/veiron-ops
VEIRON_BACKUP_IMAGE=ghcr.io/andreidohot/veiron-backup-scheduler
BASE_DOMAIN=dohotstudio.com
NODE_NAME=bootstrap-eu-1
ADMIN_EMAIL=contact@dohotstudio.com
ADMIN_USER=veiron-admin
CONTROL_ROLE=controller
CONTROLLER_URL=
ENROLLMENT_TOKEN=
RELEASE_BUNDLE_URL=
CONTROL_HOST=control.dohotstudio.com
RPC_HOST=rpc.dohotstudio.com
FLEET_HOST=fleet.dohotstudio.com
GRAFANA_HOST=grafana.dohotstudio.com
PROMETHEUS_HOST=prometheus.dohotstudio.com
POOL_HOST=pool.dohotstudio.com
P2P_HOST=node.dohotstudio.com
HTTP_PORT=80
HTTPS_PORT=443
P2P_PORT=20787
SEED_NODES_TOML=
OPS_BOOTSTRAP_PORT=8080
CLOUDFLARE_MODE=tunnel
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_NAME=veiron-control-plane
PUBLIC_IPV4=
CLOUDFLARE_PROXY_HTTP=true
ENABLE_POOL=false
POOL_NAME=Veiron Reference Pool
POOL_ADDRESS=
INDEXER_INTERVAL_SECONDS=15
PROMETHEUS_RETENTION=30d
LOKI_RETENTION_HOURS=720
GRAFANA_ADMIN_USER=admin
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=30
CHAIN_SNAPSHOT_STOP_SERVICES=true
BACKUP_REMOTE_ENABLED=false
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_REGION=auto
NODE_MEMORY_LIMIT=3G
RPC_MEMORY_LIMIT=3G
CONTROL_MEMORY_LIMIT=1G
INDEXER_MEMORY_LIMIT=1G
