local.file_match "docker_logs" {
  path_targets = [{ __path__ = "/var/lib/docker/containers/*/*-json.log", job = "docker-containers" }]
}
loki.source.file "docker_logs" { targets = local.file_match.docker_logs.targets forward_to = [loki.write.local.receiver] }
loki.write "local" { endpoint { url = "http://loki:3100/loki/api/v1/push" } }
