{
    "name":  "vireon-desktop-tauri",
    "private":  true,
    "version":  "1.0.0",
    "type":  "module",
    "description":  "Vireon Control Center - Tauri desktop shell",
    "author":  "Vireon Network \u003cadmin@vireon.network\u003e",
    "scripts":  {
                    "dev":  "vite",
                    "build":  "tsc \u0026\u0026 vite build",
                    "preview":  "vite preview",
                    "lint":  "tsc --noEmit",
                    "test":  "vitest run",
                    "prepare:native":  "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/prepare-native.ps1",
                    "prepare:native:sidecars":  "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/prepare-native.ps1 -WithSidecars",
                    "prepare:native:linux":  "bash ./scripts/prepare-native.sh",
                    "prepare:native:linux:sidecars":  "bash ./scripts/prepare-native.sh --with-sidecars",
                    "icons":  "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/generate-icons.ps1",
                    "smoke:critical":  "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/critical-smoke.ps1",
                    "build:keystore":  "cargo build --release --manifest-path ./native/keystore-helper/Cargo.toml",
                    "tauri":  "tauri",
                    "tauri:dev":  "npm run prepare:native \u0026\u0026 tauri dev",
                    "tauri:build":  "npm run prepare:native:sidecars \u0026\u0026 tauri build",
                    "tauri:build:windows":  "npm run prepare:native:sidecars \u0026\u0026 tauri build --bundles nsis,msi",
                    "tauri:build:linux":  "npm run prepare:native:linux:sidecars \u0026\u0026 tauri build --bundles deb,appimage,rpm"
                },
    "dependencies":  {
                         "@fontsource/jetbrains-mono":  "^5.2.5",
                         "@fontsource/space-grotesk":  "^5.2.5",
                         "@tauri-apps/api":  "^2",
                         "@tauri-apps/plugin-dialog":  "^2",
                         "@tauri-apps/plugin-notification":  "^2",
                         "@tauri-apps/plugin-opener":  "^2",
                         "lucide-react":  "^0.468.0",
                         "qrcode.react":  "^4.2.0",
                         "react":  "^19.1.0",
                         "react-dom":  "^19.1.0"
                     },
    "devDependencies":  {
                            "@tauri-apps/cli":  "^2",
                            "@types/node":  "^22.15.30",
                            "@types/react":  "^19.1.8",
                            "@types/react-dom":  "^19.1.6",
                            "@vitejs/plugin-react":  "^4.6.0",
                            "typescript":  "~5.8.3",
                            "vite":  "^7.0.4",
                            "vitest":  "^4.1.10"
                        }
}
