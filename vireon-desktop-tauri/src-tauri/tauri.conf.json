{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vireon Control Center",
  "version": "1.0.0",
  "identifier": "network.vireon.control-center",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vireon Control Center",
        "width": 1600,
        "height": 900,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "backgroundColor": "#030C12"
      }
    ],
    "security": {
      "csp": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' http://127.0.0.1:* http://localhost:* https: ws://127.0.0.1:* ws://localhost:*; worker-src 'self'; media-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "deb", "appimage", "rpm"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Vireon Mainnet Candidate Control Center",
    "longDescription": "Wallet, CUDA-only FiroPoW 0.9.4 GPU miner and chain visibility for Vireon Network via VPS RPC or local stack. Cross-platform Tauri shell for Windows and Linux.",
    "resources": [
      "resources/**/*"
    ],
    "externalBin": [
      "binaries/vireon-keystore-helper"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "libsecret-1-0",
          "zenity"
        ],
        "section": "utils",
        "priority": "optional",
        "files": {}
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "libappindicator-gtk3",
          "libsecret",
          "zenity"
        ]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
